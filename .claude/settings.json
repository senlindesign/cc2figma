{
  "permissions": {
    "allow": [
      "mcp__figma__whoami",
      "mcp__figma__get_metadata",
      "mcp__figma__get_libraries",
      "mcp__figma__use_figma",
      "mcp__figma__get_screenshot",
      "mcp__figma__search_design_system",
      "mcp__figma__get_variable_defs"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__figma__use_figma",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'QA REMINDER: If nodes were created or modified, verify style/variable bindings. Load figma-qa-verifier and check all returned node IDs.'"
          }
        ]
      }
    ]
  }
}
